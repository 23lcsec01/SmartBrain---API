# Server Configuration
PORT=3000

# Database Configuration (Neon or Supabase connection string)
DATABASE_URL=postgres://username:password@hostname:port/dbname

# Hugging Face Configuration
# Create a token with read/inference permission at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_hugging_face_token_here

# The model to use for face detection. Defaults to arnabdhar/YOLOv8-Face-Detection if not set.
HF_MODEL=arnabdhar/YOLOv8-Face-Detection
